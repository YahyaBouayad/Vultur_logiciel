# ─────────────────────────────────────────────
#  VULTUR — Variables d'environnement production
#  Copie ce fichier en ".env" et remplis les valeurs
#  NE JAMAIS committer le fichier .env sur Git
# ─────────────────────────────────────────────

# Base de données
DB_USER=vultur
DB_PASSWORD=MOT_DE_PASSE_FORT_ICI

# Clef secrète JWT — génère avec :
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=REMPLACE_PAR_UNE_VRAIE_CLEF

# Domaines (sans https://)
APP_DOMAIN=app.tondomaine.com
API_DOMAIN=api.tondomaine.com
